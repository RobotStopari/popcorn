rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && adminDoc().data.admin == true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.admin == false;

      allow update: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.admin == resource.data.get('admin', false);

      allow update: if isAdmin()
        && userId != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['admin', 'updatedAt']);

      allow delete: if isOwner(userId);

      allow delete: if isAdmin()
        && userId != request.auth.uid
        && get(/databases/$(database)/documents/users/$(userId)).data.get('admin', false) == false;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || guestShareEventUpdate(eventId);
    }

    function shareLinkDoc(shareId) {
      return get(/databases/$(database)/documents/eventShareLinks/$(shareId));
    }

    function shareLinkEditable(shareId) {
      let link = shareLinkDoc(shareId).data;
      return link.active == true
        && (link.expiresAt == null || link.expiresAt > request.time);
    }

    function guestShareEventUpdate(eventId) {
      let shareId = request.resource.data._shareEditId;
      return shareId is string
        && shareId.size() >= 32
        && exists(/databases/$(database)/documents/eventShareLinks/$(shareId))
        && shareLinkDoc(shareId).data.eventId == eventId
        && shareLinkEditable(shareId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'dateStart',
          'timeStart',
          'dateEnd',
          'timeEnd',
          'place',
          'price',
          'description',
          'organisers',
          'participants',
          'registrationLink',
          'report',
          'galleryLink',
          'coverImage',
          'coverPublicId',
          'promoImages',
          'galleryPicks',
          'category',
          'externalPageEnabled',
          'externalPageUrl',
          'calendarOnly',
          'published',
          'updatedAt',
          '_shareEditId',
        ]);
    }

    match /eventShareLinks/{shareId} {
      allow read: if true;
      allow list: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'eventId',
          'expiresAt',
          'maxUses',
          'openCount',
          'active',
          'label',
          'createdAt',
          'createdBy',
        ])
        && request.resource.data.eventId is string
        && request.resource.data.openCount == 0
        && request.resource.data.active == true;
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || guestShareLinkOpenUpdate();
    }

    function guestShareLinkOpenUpdate() {
      let link = resource.data;
      let next = request.resource.data;
      let currentOpens = link.get('openCount', 0);
      return next.diff(link).affectedKeys().hasOnly(['openCount', 'lastOpenedAt'])
        && next.openCount == currentOpens + 1
        && link.get('active', false) == true
        && (link.get('expiresAt', null) == null || link.get('expiresAt', null) > request.time)
        && (link.get('maxUses', null) == null || currentOpens < link.get('maxUses', null));
    }

    function hasCompleteProfile() {
      return isSignedIn()
        && adminDoc().data.name is string
        && adminDoc().data.name.size() > 0;
    }

    function isBlogPostAuthor(data) {
      return isSignedIn()
        && data.author is map
        && data.author.uid == request.auth.uid;
    }

    function validBlogAuthor(author) {
      return author is map
        && author.uid is string
        && author.uid.size() > 0
        && author.name is string
        && author.name.size() > 0;
    }

    function validBlogPostCore(data) {
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.slug is string
        && data.slug.matches('^[a-z0-9]+(?:-[a-z0-9]+)*$')
        && data.body is string
        && data.body.size() > 0
        && data.keywords is list
        && data.publishedDate is string
        && data.publishedDate.size() > 0
        && data.publishedTime is string
        && data.publishedTime.size() > 0
        && validBlogAuthor(data.author);
    }

    function validBlogPostData(data) {
      return validBlogPostCore(data)
        && data.author.uid == request.auth.uid;
    }

    function validBlogPostDataAdmin(data) {
      return validBlogPostCore(data);
    }

    function blogPublishTimeUnchanged() {
      return request.resource.data.publishedDate == resource.data.publishedDate
        && request.resource.data.publishedTime == resource.data.publishedTime;
    }

    function blogAuthorUidUnchanged() {
      return request.resource.data.author.uid == resource.data.author.uid;
    }

    function blogLikeCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'updatedAt'])
        && request.resource.data.likeCount >= 0
        && (
          request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1
          || request.resource.data.likeCount == resource.data.get('likeCount', 0) - 1
        );
    }

    function blogCommentCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount', 'updatedAt'])
        && request.resource.data.commentCount >= 0
        && (
          request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1
          || request.resource.data.commentCount == resource.data.get('commentCount', 0) - 1
        );
    }

    function siteSettingsDoc() {
      return get(/databases/$(database)/documents/siteSettings/config);
    }

    function membersCanCreateBlogPosts() {
      return !exists(/databases/$(database)/documents/siteSettings/config)
        || siteSettingsDoc().data.get('membersCanCreateBlogPosts', true) == true;
    }

    function anonymousBlogLikesEnabled() {
      return !exists(/databases/$(database)/documents/siteSettings/config)
        || siteSettingsDoc().data.get('anonymousBlogLikesEnabled', true) == true;
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create: if isAdmin()
        && validBlogPostDataAdmin(request.resource.data)
        || (hasCompleteProfile()
          && membersCanCreateBlogPosts()
          && validBlogPostData(request.resource.data));
      allow update: if isAdmin()
        && validBlogPostDataAdmin(request.resource.data)
        || (hasCompleteProfile()
          && isBlogPostAuthor(resource.data)
          && blogAuthorUidUnchanged()
          && blogPublishTimeUnchanged()
          && validBlogPostData(request.resource.data))
        || blogLikeCountOnlyUpdate()
        || blogCommentCountOnlyUpdate();
      allow delete: if isAdmin()
        || (hasCompleteProfile() && isBlogPostAuthor(resource.data));

      match /likes/{likeId} {
        allow get, list: if true;

        allow create: if !exists(/databases/$(database)/documents/blogPosts/$(postId)/likes/$(likeId))
          && (
            (isSignedIn()
              && likeId == request.auth.uid
              && request.resource.data.keys().hasOnly(['uid', 'anonymous', 'createdAt'])
              && request.resource.data.uid == request.auth.uid
              && request.resource.data.anonymous == false)
            || (!isSignedIn()
              && anonymousBlogLikesEnabled()
              && request.resource.data.keys().hasOnly(['uid', 'anonymous', 'createdAt'])
              && request.resource.data.anonymous == true
              && request.resource.data.uid == null
              && likeId.matches('^anon_.+$'))
          );

        allow delete: if (isSignedIn()
          && likeId == request.auth.uid
          && resource.data.anonymous == false)
          || (resource.data.anonymous == true && likeId.matches('^anon_.+$'));
      }

      match /comments/{commentId} {
        allow get, list: if true;

        allow create: if hasCompleteProfile()
          && request.resource.data.keys().hasAll(['author', 'body', 'createdAt', 'updatedAt', 'editedAt'])
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 2000
          && request.resource.data.author is map
          && request.resource.data.author.uid == request.auth.uid
          && request.resource.data.editedAt == null;

        allow update: if hasCompleteProfile()
          && resource.data.author.uid == request.auth.uid
          && request.resource.data.author == resource.data.author
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 2000;

        allow delete: if isAdmin()
          || (hasCompleteProfile() && resource.data.author.uid == request.auth.uid);
      }
    }

    match /organiserPresets/{presetId} {
      allow read, create, update, delete: if isAdmin();
    }

    function validNotificationColor(color) {
      return color == 'orange'
        || color == 'red'
        || color == 'blue'
        || color == 'green'
        || color == 'teal';
    }

    function validNotificationIcon(icon) {
      return icon == 'notification'
        || icon == 'important'
        || icon == 'starting'
        || icon == 'ending'
        || icon == 'warning'
        || icon == 'info';
    }

    function validNotificationData(data) {
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000
        && data.scheduleMode is string
        && (data.scheduleMode == 'scheduled' || data.scheduleMode == 'manual')
        && data.manualActive is bool
        && data.dateStart is string
        && data.timeStart is string
        && data.dateEnd is string
        && data.timeEnd is string
        && validNotificationColor(data.color)
        && validNotificationIcon(data.icon)
        && data.ctaEnabled is bool
        && data.ctaLabel is string
        && data.ctaHref is string
        && data.ctaOpenInNewTab is bool;
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && validNotificationData(request.resource.data);
    }

    function validSiteTextsData() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'heroQuote',
          'upcomingIntro',
          'pastIntro',
          'blogIntro',
          'eventCategoryPublicLabel',
          'eventCategoryPublicDescription',
          'eventCategoryPrivateLabel',
          'eventCategoryPrivateDescription',
          'eventCategoryExternalLabel',
          'eventCategoryExternalDescription',
          'updatedAt',
        ])
        && data.heroQuote is string
        && data.upcomingIntro is string
        && data.pastIntro is string
        && data.blogIntro is string
        && data.eventCategoryPublicLabel is string
        && data.eventCategoryPublicDescription is string
        && data.eventCategoryPrivateLabel is string
        && data.eventCategoryPrivateDescription is string
        && data.eventCategoryExternalLabel is string
        && data.eventCategoryExternalDescription is string;
    }

    match /siteTexts/{docId} {
      allow read: if true;

      allow create: if isAdmin()
        && docId == 'config'
        && validSiteTextsData();

      allow update: if isAdmin()
        && docId == 'config'
        && validSiteTextsData();

      allow delete: if false;
    }

    function isProtectedPage(pageId) {
      return pageId == 'home'
        || pageId == 'vypukne'
        || pageId == 'probehle'
        || pageId == 'blog';
    }

    function validPageType(type) {
      return type == 'home'
        || type == 'events-upcoming'
        || type == 'events-past'
        || type == 'blog-list'
        || type == 'content';
    }

    function validPageSlug(slug) {
      return slug == ''
        || slug.matches('^[a-z0-9]+(-[a-z0-9]+)*$');
    }

    function validPageBlocks(blocks) {
      return blocks is list
        && blocks.size() <= 50;
    }

    function validPageFields() {
      let data = request.resource.data;
      return data.keys().hasAll(['slug', 'title', 'type'])
        && data.title is string
        && data.title.size() > 0
        && data.slug is string
        && data.type is string
        && validPageType(data.type)
        && validPageSlug(data.slug)
        && (data.type != 'home' || data.slug == '')
        && (data.type == 'home' || data.slug.size() > 0)
        && (!data.keys().hasAny(['blocks']) || validPageBlocks(data.blocks))
        && (!data.keys().hasAny(['intro']) || data.intro is string);
    }

    function validSiteSettingsFooterSlot(slot) {
      return slot is map
        && slot.keys().hasOnly(['preset', 'enabled'])
        && slot.preset is string
        && slot.enabled is bool;
    }

    function validSiteSettingsFooterSlots(slots) {
      return slots is list
        && slots.size() == 3
        && validSiteSettingsFooterSlot(slots[0])
        && validSiteSettingsFooterSlot(slots[1])
        && validSiteSettingsFooterSlot(slots[2]);
    }

    function validSiteSettingsBrandLinks(links) {
      return links is map
        && links.keys().hasOnly(['instagram', 'facebook', 'mail', 'youtube', 'tiktok', 'linkedin'])
        && links.instagram is string
        && links.facebook is string
        && links.mail is string
        && links.youtube is string
        && links.tiktok is string
        && links.linkedin is string;
    }

    function validSiteSettingsPatch() {
      let data = request.resource.data;
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly([
          'logoUrl',
          'logoPublicId',
          'logoAlt',
          'brandLine1',
          'brandLine2',
          'footerYear',
          'footerContactLabel',
          'footerContactEmail',
          'brandLinks',
          'footerSocialSlots',
          'comingSoonEnabled',
          'anonymousBlogLikesEnabled',
          'membersCanCreateBlogPosts',
          'eventCategoryPublicLabel',
          'eventCategoryPublicDescription',
          'eventCategoryPrivateLabel',
          'eventCategoryPrivateDescription',
          'eventCategoryExternalLabel',
          'eventCategoryExternalDescription',
          'updatedAt',
        ])
        && (!keys.hasAny(['logoUrl']) || data.logoUrl is string)
        && (!keys.hasAny(['logoPublicId']) || data.logoPublicId is string)
        && (!keys.hasAny(['logoAlt']) || data.logoAlt is string)
        && (!keys.hasAny(['brandLine1']) || data.brandLine1 is string)
        && (!keys.hasAny(['brandLine2']) || data.brandLine2 is string)
        && (!keys.hasAny(['footerYear']) || data.footerYear is string)
        && (!keys.hasAny(['footerContactLabel']) || data.footerContactLabel is string)
        && (!keys.hasAny(['footerContactEmail']) || data.footerContactEmail is string)
        && (!keys.hasAny(['brandLinks']) || validSiteSettingsBrandLinks(data.brandLinks))
        && (!keys.hasAny(['footerSocialSlots']) || validSiteSettingsFooterSlots(data.footerSocialSlots))
        && (!keys.hasAny(['comingSoonEnabled']) || data.comingSoonEnabled is bool)
        && (!keys.hasAny(['anonymousBlogLikesEnabled']) || data.anonymousBlogLikesEnabled is bool)
        && (!keys.hasAny(['membersCanCreateBlogPosts']) || data.membersCanCreateBlogPosts is bool)
        && (!keys.hasAny(['eventCategoryPublicLabel']) || data.eventCategoryPublicLabel is string)
        && (!keys.hasAny(['eventCategoryPublicDescription']) || data.eventCategoryPublicDescription is string)
        && (!keys.hasAny(['eventCategoryPrivateLabel']) || data.eventCategoryPrivateLabel is string)
        && (!keys.hasAny(['eventCategoryPrivateDescription']) || data.eventCategoryPrivateDescription is string)
        && (!keys.hasAny(['eventCategoryExternalLabel']) || data.eventCategoryExternalLabel is string)
        && (!keys.hasAny(['eventCategoryExternalDescription']) || data.eventCategoryExternalDescription is string);
    }

    function validSiteSettingsCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'logoUrl',
          'logoPublicId',
          'logoAlt',
          'brandLine1',
          'brandLine2',
          'footerYear',
          'footerContactLabel',
          'footerContactEmail',
          'brandLinks',
          'footerSocialSlots',
          'comingSoonEnabled',
          'anonymousBlogLikesEnabled',
          'membersCanCreateBlogPosts',
          'eventCategoryPublicLabel',
          'eventCategoryPublicDescription',
          'eventCategoryPrivateLabel',
          'eventCategoryPrivateDescription',
          'eventCategoryExternalLabel',
          'eventCategoryExternalDescription',
          'updatedAt',
        ])
        && data.logoUrl is string
        && data.logoPublicId is string
        && data.logoAlt is string
        && data.brandLine1 is string
        && data.brandLine2 is string
        && data.footerYear is string
        && data.footerContactLabel is string
        && data.footerContactEmail is string
        && validSiteSettingsBrandLinks(data.brandLinks)
        && validSiteSettingsFooterSlots(data.footerSocialSlots)
        && data.comingSoonEnabled is bool
        && data.anonymousBlogLikesEnabled is bool
        && data.membersCanCreateBlogPosts is bool
        && data.eventCategoryPublicLabel is string
        && data.eventCategoryPublicDescription is string
        && data.eventCategoryPrivateLabel is string
        && data.eventCategoryPrivateDescription is string
        && data.eventCategoryExternalLabel is string
        && data.eventCategoryExternalDescription is string;
    }

    match /siteSettings/{docId} {
      allow read: if true;

      allow create: if isAdmin()
        && docId == 'config'
        && validSiteSettingsCreate();

      allow update: if isAdmin()
        && docId == 'config'
        && validSiteSettingsPatch();

      allow delete: if false;
    }

    match /pages/{pageId} {
      allow read: if true;

      allow create: if isAdmin() && validPageFields();

      allow update: if isAdmin()
        && validPageFields()
        && request.resource.data.type == resource.data.type
        && (pageId != 'home'
          || (request.resource.data.title == resource.data.title
            && request.resource.data.slug == resource.data.slug));

      allow delete: if isAdmin() && !isProtectedPage(pageId);
    }

    match /siteMenu/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && docId == 'config';
      allow delete: if false;
    }

    function validHexColor(value) {
      return value is string
        && value.matches('^#([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$');
    }

    function validSiteColorMap(colors) {
      return colors is map
        && validHexColor(colors.orange)
        && validHexColor(colors.orangeLight)
        && validHexColor(colors.orangeDark)
        && validHexColor(colors.orangePale)
        && validHexColor(colors.red)
        && validHexColor(colors.redLight)
        && validHexColor(colors.redPale)
        && validHexColor(colors.blue)
        && validHexColor(colors.blueLight)
        && validHexColor(colors.bluePale)
        && validHexColor(colors.green)
        && validHexColor(colors.greenLight)
        && validHexColor(colors.greenPale)
        && validHexColor(colors.teal)
        && validHexColor(colors.tealLight)
        && validHexColor(colors.tealPale)
        && validHexColor(colors.yellow)
        && validHexColor(colors.yellowPale)
        && validHexColor(colors.black)
        && validHexColor(colors.white)
        && validHexColor(colors.offWhite)
        && validHexColor(colors.gray)
        && validHexColor(colors.grayMuted);
    }

    function validSiteColorsData() {
      let data = request.resource.data;
      return data.keys().hasOnly(['colors', 'updatedAt'])
        && validSiteColorMap(data.colors);
    }

    match /siteColors/{docId} {
      allow read: if true;

      allow create: if isAdmin()
        && docId == 'config'
        && validSiteColorsData();

      allow update: if isAdmin()
        && docId == 'config'
        && validSiteColorsData();

      allow delete: if false;
    }
  }
}
