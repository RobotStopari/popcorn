# Firebase web app config (Firebase Console → Project settings → Your apps → Web app)
# These values are injected at build time by Vite. Do not commit .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public site URL for canonical links, sitemap, and Open Graph (no trailing slash)
VITE_SITE_URL=https://komunita-popcorn.cz

# Cloudflare Worker SSR — set the same Firebase values in production (Dashboard → Worker → Settings → Variables)
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=
# SITE_URL=https://komunita-popcorn.cz

# Cloudinary — event & blog images (viz README → Cloudinary setup)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_PRESET_COVER=popcorn_event_cover
VITE_CLOUDINARY_PRESET_PROMO=popcorn_event_pr
VITE_CLOUDINARY_PRESET_GALLERY=popcorn_event_gallery
VITE_CLOUDINARY_PRESET_POST=popcorn_post_cover
VITE_CLOUDINARY_PRESET_POST_GALLERY=popcorn_post_gallery
VITE_CLOUDINARY_PRESET_SITE_LOGO=popcorn_site_logo
# Legacy fallback for cover preset only:
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional — Instagram feed username (Cloudflare Worker, default: popcorn_puk)
# INSTAGRAM_USERNAME=popcorn_puk

